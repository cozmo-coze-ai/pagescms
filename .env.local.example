# BASE_URL="https://mycustomdomain.com" # In production, set this to the single canonical app URL.
# ADMIN_EMAILS="admin@example.com,other-admin@example.com"
BETTER_AUTH_SECRET="random-string-of-characters"
# EMAIL_PROVIDER="resend" # or "smtp"
EMAIL_FROM="Coze CMS <no-reply@coze.care>"
# Resend config
# RESEND_API_KEY="your-resend-api-key"
# RESEND_FROM_EMAIL="Coze CMS <no-reply@coze.care>" # backwards-compatible alias for EMAIL_FROM
# SMTP config
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
DATABASE_URL="postgresql://cozecms:cozecms@localhost:5432/cozecms"
# Runtime DB connection (pooled) — required in addition to DATABASE_URL/
# migrations' SG_DATABASE_URL_UNPOOLED; db/index.ts reads this one at runtime.
SG_POSTGRES_URL="postgresql://...pooler.supabase.com:5432/postgres"
# Migrations only (drizzle.config.ts) — session/unpooled connection.
SG_DATABASE_URL_UNPOOLED="postgresql://...pooler.supabase.com:5432/postgres"
# Supabase Storage (itinerary media). Project: coze (ihitnwzljfldctswwrsv, ap-northeast-2).
# SUPABASE_SERVICE_ROLE_KEY is server-only — never expose it to the client.
SUPABASE_URL="https://ihitnwzljfldctswwrsv.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Vercel deploy hook for the coze_client project — POSTed after a successful
# save so the public site rebuilds without a manual trigger.
COZE_CLIENT_DEPLOY_HOOK_URL="https://api.vercel.com/v1/integrations/deploy/..."
